# Copy to `.env.local` and fill in values.

# Sentry (org: lifenode-systems, project: javascript-nextjs)
# DSN: Sentry → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Source map upload on production builds (Sentry → Settings → Auth Tokens)
SENTRY_AUTH_TOKEN=
# Generate AUTH_SECRET: `npx auth secret`  OR  `openssl rand -base64 32`

AUTH_SECRET=

# Base URL of this app (used for OAuth redirects). Example: http://localhost:3000
AUTH_URL=http://localhost:3000

# Google OAuth — Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — GitHub → Settings → Developer settings → OAuth Apps
# Authorization callback URL: {AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Supabase (app/lifenode-os — also used by `npm run db:push`)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# CLI: Dashboard → Account → Access Tokens (after `npx supabase login`, optional)
SUPABASE_ACCESS_TOKEN=
# CLI: Project Settings → Database → database password
SUPABASE_DB_PASSWORD=
# Optional override if URL is unset
SUPABASE_PROJECT_REF=

# Kitchen AI image cap (only when CHEF_MULTIMODAL_IMAGES=1). Set to 1 in local dev to skip.
# SKIP_KITCHEN_IMAGE_CAP=1
# KITCHEN_IMAGE_DAILY_CAP=50

# Unified AI metering (/api/chat, /api/vanode/ai, etc.). Set to 1 in local dev to skip.
# SKIP_AI_METERING=1
# ChefNode: 0/off = fast text recipes + Pollinations hero images (recommended).
# CHEF_MULTIMODAL_IMAGES=0
# ChefNode multimodal (Nano Banana 2 image+recipe) — only when set to 1/true/yes/on:
# CHEF_MULTIMODAL_IMAGES=1
# GOOGLE_GEMINI_CHEF_IMAGE_MODEL=gemini-3.1-flash-image-preview
# GOOGLE_GEMINI_TEXT_MODEL=gemini-2.0-flash
# GOOGLE_GEMINI_VISION_MODEL=gemini-2.0-flash

# AI chat (optional — Linos Assistant). Do NOT point this at a non-image model for ChefNode multimodal.
GOOGLE_API_KEY=
GOOGLE_GEMINI_MODEL=gemini-2.5-flash

# Dev only: skip server reads/writes for shell hats, last active node, and workflows.
# Every page load shows a fresh onboarding. MUST be 0 (or unset) for production.
NEXT_PUBLIC_LIFENODE_DEV_FRESH_SESSION=0

# Termly CMP — website UUID from Dashboard → Install (resource-blocker snippet).
# Default in code: 686781d8-505a-4c34-964a-ff53dc7674df — override if you use another site.
NEXT_PUBLIC_TERMLY_WEBSITE_UUID=686781d8-505a-4c34-964a-ff53dc7674df

# Termly policy embed IDs (optional — defaults match exported terms / cookie policies).
NEXT_PUBLIC_TERMLY_TERMS_POLICY_ID=
NEXT_PUBLIC_TERMLY_COOKIE_POLICY_ID=

# Transactional email (activation + password reset) via Resend.
# Verify support@lifenodeos.com in Resend before production sends.
RESEND_API_KEY=
LIFENODE_EMAIL_FROM=LifeNode OS <support@lifenodeos.com>

# Lemon Squeezy billing (Sync / Nexus — Core is free, no checkout)
# Dashboard → Settings → API → create API key; Store ID on store settings page.
# Create webhook → POST {AUTH_URL}/api/billing/lemonsqueezy/webhook
# Events: subscription_created, subscription_updated, subscription_cancelled,
#         subscription_expired, subscription_payment_success, subscription_payment_failed
# Lemon Squeezy billing (prefer BILLING_* names; legacy LEMONSQUEEZY_* still works)
BILLING_API_KEY=
BILLING_STORE_ID=
BILLING_WEBHOOK_SECRET=
BILLING_VARIANT_SYNC_MONTHLY=
BILLING_VARIANT_SYNC_ANNUAL=
BILLING_VARIANT_NEXUS_MONTHLY=
BILLING_VARIANT_NEXUS_ANNUAL=
# Nexus list prices: $59/mo monthly, $49/mo billed annually ($588/year). Match Lemon variant amounts.

# VANode / BizNode OAuth (add redirect URIs in each provider console)
# Google Drive + Gmail + Calendar share GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET above.
# Zoom — https://marketplace.zoom.us/develop/create
# Redirect: {NEXT_PUBLIC_APP_URL}/api/integrations/zoom/callback
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# Vercel Cron — random secret; Vercel sends `Authorization: Bearer <CRON_SECRET>` on cron hits.
# Generate: openssl rand -base64 32
CRON_SECRET=
