{
  "name": "lifenode-os-workspace",
  "private": true,
  "description": "Run npm scripts from this folder; the Next.js app is in app/lifenode-os.",
  "scripts": {
    "dev": "npm run dev --prefix app/lifenode-os",
    "dev:clean": "npm run dev:clean --prefix app/lifenode-os",
    "build": "npm run build --prefix app/lifenode-os",
    "start": "npm run build --prefix app/lifenode-os && npm run start --prefix app/lifenode-os",
    "clean": "npm run clean --prefix app/lifenode-os",
    "lint": "npm run lint --prefix app/lifenode-os",
    "supabase:link": "npm run supabase:link --prefix app/lifenode-os",
    "db:push": "npm run db:push --prefix app/lifenode-os",
    "review:changes": "tsx scripts/review-changes.ts"
  },
  "dependencies": {
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "lucide-react": "^1.16.0",
    "openai": "^6.39.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.18",
    "@types/node": "^22.15.0",
    "@types/html-to-text": "^9.0.4",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3"
  }
}
